<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Reads WiFi signal strength and link speed for the header gauge.
         No location permission needed since we never read the SSID/BSSID. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Mobile network type (5G/LTE/3G) in the header on cellular tablets.
         Normal permission on API 33+; older devices fall back to plain "Mobile". -->
    <uses-permission android:name="android.permission.READ_BASIC_PHONE_STATE" />

    <!-- Optional "Use device location" action in Settings. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Optional calendar card on the Info page (asked on demand). -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />

    <application
        android:name=".FsClockApp"
        android:label="@string/app_name"
        android:icon="@drawable/ic_launcher"
        android:allowBackup="false"
        android:theme="@style/DreamTheme">

        <!-- Compose home screen = the app's launcher and boot target. -->
        <activity
            android:name=".ComposeHomeActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:icon="@drawable/ic_launcher"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboard|keyboardHidden"
            android:theme="@style/DreamTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Screensaver (daydream) variant of the home screen. -->
        <service
            android:name=".ArkDreamService"
            android:exported="true"
            android:permission="android.permission.BIND_DREAM_SERVICE">
            <intent-filter>
                <action android:name="android.service.dreams.DreamService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </service>

        <receiver
            android:name=".BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
